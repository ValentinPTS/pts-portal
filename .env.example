# Copy to .env.local and fill in. NEVER commit real values.
# Without these, the app runs on an in-memory store. With them, it persists to Supabase.
# See SUPABASE-SETUP.md.

# Supabase — your dedicated PTS project, EU region (Frankfurt)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=                 # publishable/anon key (Phase 1). Server-side only.
                                # Phase 2: switch to a secret server key + auth-scoped RLS.

# ── Owner authentication (Phase 2) ──────────────────────────────────────────
# Auth is SCAFFOLDED OFF by default — the app stays open. To switch it on:
#   1) set AUTH_ENABLED=true
#   2) set NEXT_PUBLIC_SUPABASE_ANON_KEY to the publishable/anon key (browser-safe)
#   3) set OWNER_EMAILS to the 3 owners' login emails (comma-separated)
#   4) create those users in Supabase Auth; each enrols an authenticator app (TOTP) at /account
# Until the /login + /account UI is built and the above is set, leave AUTH_ENABLED unset.
# AUTH_ENABLED=true
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# OWNER_EMAILS=belovski@example.com,kasabova@example.com,partner@example.com
# With auth ON, set a long random secret so owner PDF export works (the headless
# browser uses it to fetch render routes past the owner-area gate). Keep it secret.
# INTERNAL_TOKEN=<64+ random hex chars>

# Claude API (BG→EN translate helper) — server-only (Phase 1 optional)
# ANTHROPIC_API_KEY=

# PAdES document signing certificate (Phase 3) — server-only
# SIGNING_CERT_PATH=
# SIGNING_CERT_PASSPHRASE=
